       " Document(metadata={'source': 'files/medical-law-2026-04.pdf', 'coordinates': {'points': ((46.0, 757.0), (46.0, 767.0), (557.1199999999999, 767.0), (557.1199999999999, 757.0)), 'system': 'PixelSpace', 'layout_width': 595.0, 'layout_height': 842.0}, 'file_directory': 'files', 'filename': 'medical-law-2026-04.pdf', 'last_modified': '2026-06-17T21:37:27', 'page_number': 4, 'languages': ['kor'], 'filetype': 'application/pdf', 'parent_id': '784eae6e7c7fe063cac79f06b8054146', 'category': 'NarrativeText', 'element_id': 'e803aca6ae70d81952e79f47ec6b5e4f'}, page_content='보호자 등이 상주하지 아니하고 간호사, 간호조무사 및 그 밖에 간병지원인력(이하 이 조에서 “간호ㆍ간병통합서비'),\n",
       " Document(metadata={'source': 'files/medical-law-2026-04.pdf', 'coordinates': {'points': ((37.92, 804.0), (37.92, 814.0), (557.0699999999993, 814.0), (557.0699999999993, 804.0)), 'system': 'PixelSpace', 'layout_width': 595.0, 'layout_height': 842.0}, 'file_directory': 'files', 'filename': 'medical-law-2026-04.pdf', 'last_modified': '2026-06-17T21:37:27', 'page_number': 4, 'languages': ['kor'], 'filetype': 'application/pdf', 'category': 'Footer', 'element_id': '559a54731db16151f8f38ce1ca059f61'}, page_content='법제처 4 국가법령정보센터'),\n",
       " Document(metadata={'source': 'files/medical-law-2026-04.pdf', 'coordinates': {'points': ((535.0, 31.409999999999968), (535.0, 41.40999999999997), (565.0, 41.40999999999997), (565.0, 31.409999999999968)), 'system': 'PixelSpace', 'layout_width': 595.0, 'layout_height': 842.0}, 'file_directory': 'files', 'filename': 'medical-law-2026-04.pdf', 'last_modified': '2026-06-17T21:37:27', 'page_number': 4, 'languages': ['kor'], 'filetype': 'application/pdf', 'category': 'Header', 'element_id': '689e5c97fbdec106cca7dbd7f67152a6'}, page_content='의료법'),\n",
