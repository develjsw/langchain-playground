       " Document(metadata={'source': 'files/medical-law-2026-04.pdf', 'coordinates': {'points': ((50.0, 63.0), (50.0, 73.0), (199.73000000000002, 73.0), (199.73000000000002, 63.0)), 'system': 'PixelSpace', 'layout_width': 595.0, 'layout_height': 842.0}, 'file_directory': 'files', 'filename': 'medical-law-2026-04.pdf', 'last_modified': '2026-06-17T21:37:27', 'page_number': 3, 'languages': ['kor'], 'filetype': 'application/pdf', 'parent_id': '1fe40ce945012f5b8d77f19d90bb6d32', 'category': 'Title', 'element_id': '0fb786cf587f62ff9903a03ec0a88380'}, page_content='하지 아니한 전문의를 둘 수 있다.'),\n",
