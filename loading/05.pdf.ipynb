       " Document(metadata={'source': 'files/medical-law-2026-04.pdf', 'coordinates': {'points': ((50.0, 599.0), (50.0, 609.0), (564.9911899999997, 609.0), (564.9911899999997, 599.0)), 'system': 'PixelSpace', 'layout_width': 595.0, 'layout_height': 842.0}, 'file_directory': 'files', 'filename': 'medical-law-2026-04.pdf', 'last_modified': '2026-06-17T21:37:27', 'page_number': 15, 'languages': ['kor'], 'filetype': 'application/pdf', 'parent_id': '2ed3f71815aa4812e622147a6deee981', 'category': 'Title', 'element_id': 'b610195f9ed96166f03a0c1bc579bab0'}, page_content='③ 의료인은 진료기록부등을 거짓으로 작성하거나 고의로 사실과 다르게 추가기재ㆍ수정하여서는 아니 된다.<신설'),\n",
       " Document(metadata={'source': 'files/medical-law-2026-04.pdf', 'coordinates': {'points': ((50.0, 615.0), (50.0, 625.0), (103.69877, 625.0), (103.69877, 615.0)), 'system': 'PixelSpace', 'layout_width': 595.0, 'layout_height': 842.0}, 'file_directory': 'files', 'filename': 'medical-law-2026-04.pdf', 'last_modified': '2026-06-17T21:37:27', 'page_number': 15, 'languages': ['kor'], 'filetype': 'application/pdf', 'parent_id': 'b610195f9ed96166f03a0c1bc579bab0', 'category': 'ListItem', 'element_id': '581e34071f673b3823edece0a8cbf8f8'}, page_content='2011. 4. 7.>'),\n",
